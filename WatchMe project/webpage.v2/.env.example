NODE_ENV=development
# Production VPS (example): 3103 — keep in sync with Caddy upstream.
WEB_V2_API_PORT=3102
WEB_V2_SITE_NAME=WatchMe Web V2
WEB_V2_PUBLIC_ORIGIN=http://127.0.0.1:5174
WEB_V2_ALLOWED_ORIGINS=http://127.0.0.1:5174
# Use a long random secret in production; never commit real values.
WEB_V2_SESSION_SECRET=change-me
WEB_V2_DISCORD_CLIENT_ID=
WEB_V2_DISCORD_CLIENT_SECRET=
WEB_V2_DISCORD_REDIRECT_URI=http://127.0.0.1:3102/auth/discord/callback
WEB_V2_DISCORD_EXTRA_HOSTS=
WEB_V2_DISCORD_OAUTH_TIMEOUT_MS=25000
WEB_V2_SESSION_COOKIE_SECURE=auto
WEB_V2_PAYPAL_PLAN_ID=
# Pro V2 API (dashboard proxy): internal URL + INTERNAL_API_TOKEN (same as Pro, or scoped token)
WEB_V2_PRO_V2_API_BASE_URL=http://127.0.0.1:3101
WEB_V2_PRO_V2_API_TOKEN=
