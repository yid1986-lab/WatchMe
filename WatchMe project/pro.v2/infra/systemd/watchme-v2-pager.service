[Unit]
Description=WatchMe V2 ops pager loop
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=watchme
Group=watchme
WorkingDirectory=/opt/watchme-v2
EnvironmentFile=-/etc/watchme-v2/pager.env
ExecStart=/usr/bin/node scripts/ops-pager-loop.js
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
