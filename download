# Node 20+ recommended (.nvmrc / package.json engines). VPS checklist: docs/vps-deploy.md
NODE_ENV=development

API_PORT=3101
WORKER_NAME=watchme-v2-worker
WORKER_PORT=3102
WEB_PORT=3100

DATABASE_URL=postgres://watchme:watchme@127.0.0.1:5432/watchme_v2
# Backup / restore drill: install PostgreSQL client tools (pg_dump, pg_restore), then:
#   npm run pg:backup
#   npm run pg:restore-drill -- --backup=.local/backups/pg/<file>.dump --confirm
# Use a dedicated value in production. Legacy SESSION_SECRET fallback is for local/staged compatibility only.
INTERNAL_API_TOKEN=
# Use a dedicated value in production. Legacy SESSION_SECRET fallback is for local/staged compatibility only.
PUBLIC_API_WRITE_TOKEN=
# Use a dedicated value in production. Legacy PUBLIC_API_WRITE_TOKEN / SESSION_SECRET fallbacks are for local/staged compatibility only.
LITE_API_WRITE_TOKEN=
# Use a dedicated value in production. Legacy PUBLIC_API_WRITE_TOKEN / SESSION_SECRET fallbacks are for local/staged compatibility only.
MOBILE_API_WRITE_TOKEN=
# Use a dedicated value in production. Legacy SESSION_SECRET fallback is for local/staged compatibility only.
MOBILE_SESSION_SECRET=
# Production should keep this enabled so creator/mobile routes require a signed user session.
MOBILE_SESSION_REQUIRED=true
# Signed creator/mobile session lifetime in seconds (clamped to 60..86400).
MOBILE_SESSION_TTL_SECONDS=3600
OPS_BACKLOG_WARNING_SECONDS=300
OPS_LEASE_WARNING_SECONDS=3600
OPS_WORKER_HEARTBEAT_WARNING_SECONDS=90
OPS_WORKER_RSS_WARNING_BYTES=536870912
OPS_WORKER_HEAP_WARNING_BYTES=268435456
OPS_PAGER_MIN_SEVERITY=high
OPS_PAGER_COOLDOWN_SECONDS=900
OPS_PAGER_REMINDER_SECONDS=3600
OPS_PAGER_SEND_RECOVERY=true
OPS_PAGER_DISCORD_WEBHOOK_URL=
OPS_PAGER_SERVICE_NAME=WatchMe V2
# Loop runner (`npm run dev:pager`): seconds between POST /api/internal/ops/paging/run
OPS_PAGER_LOOP_INTERVAL_SECONDS=60
# Escalation: worker start events inside this window, including repeated starts of the same running worker
OPS_WORKER_RESTART_STORM_WINDOW_SECONDS=900
OPS_WORKER_RESTART_STORM_MIN_COUNT=3
# Escalation: repeated failed Discord webhook deliveries for the pager
OPS_PAGER_DELIVERY_FAIL_WINDOW_SECONDS=3600
OPS_PAGER_DELIVERY_FAIL_MIN_COUNT=3
# Escalation: extra incident codes (*_persistent) after stale/missing heartbeats linger
OPS_ESCALATE_WORKER_HEALTH_MIN_OCCURRENCES=10
OPS_ESCALATE_WORKER_HEALTH_MIN_AGE_SECONDS=1800
# When API is not on localhost:3101 (also accepted: WATCHME_V2_API_BASE_URL)
# API_BASE_URL=http://127.0.0.1:3101

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Falls back to DISCORD_TOKEN when reusing a V1-style env file.
DISCORD_BOT_TOKEN=
DISCORD_API_BASE_URL=https://discord.com/api/v10
DISCORD_MAX_RETRIES=5
DISCORD_RETRY_BASE_MS=1000
